# Database (Railway PostgreSQL — auto-provided as DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=cambia-questo-con-una-stringa-lunga-e-casuale

# Admin di default (usato solo al primo avvio)
ADMIN_EMAIL=admin@motohub.it
ADMIN_PASSWORD=admin123

# Odoo
ODOO_URL=https://your-odoo-instance.odoo.com
ODOO_DB=your-db-name
ODOO_USERNAME=your@email.com
ODOO_API_KEY=your-api-key

# CORS — URL del frontend Railway
FRONTEND_URL=https://your-frontend.up.railway.app

# Porta (Railway la imposta automaticamente)
PORT=3001
